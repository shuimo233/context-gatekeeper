{
  "name": "context-gatekeeper",
  "version": "0.5.0",
  "description": "MCP context management with intelligent constraint detection. AutoSkill-style extraction, MemGate-style recall, MPR-style dual-mode execution. Universal install for Cursor / Claude Desktop / Claude Code / Cline / Continue.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "context-gatekeeper": "dist/mcp/server.js",
    "context-gatekeeper-cli": "bin/context-gatekeeper-cli.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "README.zh.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-for-publish.mjs",
    "build:js": "tsc",
    "copy:scripts": "node scripts/copy-for-publish.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "prepublish": "npm run build",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:agents": "tsx scripts/cross-agent-test.ts",
    "cli": "tsx scripts/cli.ts",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "mcp",
    "context",
    "agent",
    "memory",
    "constraint",
    "autoskill",
    "memgate",
    "meta-policy",
    "token",
    "universal",
    "cursor",
    "claude",
    "cline",
    "continue"
  ],
  "author": "context-gatekeeper contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shuimo233/context-gatekeeper.git"
  },
  "bugs": {
    "url": "https://github.com/shuimo233/context-gatekeeper/issues"
  },
  "homepage": "https://github.com/shuimo233/context-gatekeeper#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "sql.js": "^1.10.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^9.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "tsx": "^4.22.4",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
